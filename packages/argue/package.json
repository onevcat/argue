{
  "name": "argue",
  "version": "0.1.0",
  "description": "Harness-agnostic orchestration package for multi-agent consensus workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run check && npm run test && npm run build"
  },
  "keywords": [
    "multi-agent",
    "orchestration",
    "consensus",
    "workflow"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "^3.24.2"
  }
}
