{
  "name": "@onevcat/argue-cli",
  "version": "0.3.1",
  "description": "CLI host for argue multi-agent orchestration.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "argue": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onevcat/argue.git"
  },
  "homepage": "https://github.com/onevcat/argue",
  "bugs": {
    "url": "https://github.com/onevcat/argue/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@onevcat/argue": "^0.3.1",
    "ai": "^6.0.153",
    "jsonrepair": "^3.13.3",
    "picocolors": "^1.1.1",
    "zod": "^3.24.2"
  }
}
